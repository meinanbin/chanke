.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  z-index: 999;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.nav-content {
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 16rpx;
}

/* 返回箭头 */
.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

/* 搜索框 */
.nav-search {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f6fa;
  border-radius: 32rpx;
  padding: 0 20rpx;
  height: 64rpx;
  margin-left: 12rpx;
}
.search-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
}
.search-circle {
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #999;
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 0;
}
.search-handle {
  width: 10rpx;
  height: 3rpx;
  background: #999;
  position: absolute;
  bottom: 4rpx;
  right: 0;
  transform: rotate(45deg);
  border-radius: 2rpx;
}
.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  height: 64rpx;
  line-height: 64rpx;
}
.search-placeholder {
  color: #bbb;
  font-size: 26rpx;
}
.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.clear-text {
  font-size: 36rpx;
  color: #ccc;
  line-height: 1;
}

/* 筛选按钮 */
.nav-filter {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.filter-icon {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}
.filter-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-top: 20rpx solid #666;
}
.filter-icon::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10rpx;
  width: 8rpx;
  height: 10rpx;
  background: #666;
}
.nav-filter-placeholder {
  width: 12rpx;
  flex-shrink: 0;
}
