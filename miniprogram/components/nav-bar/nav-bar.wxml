<view class="nav-bar" style="height: {{navBarHeight}}px;">
  <!-- 状态栏占位 -->
  <view style="height: {{statusBarHeight}}px;"></view>
  <!-- 导航内容栏 -->
  <view class="nav-content">
    <!-- 左侧：返回首页箭头 -->
    <view class="nav-back" bindtap="onBack">
      <view class="back-arrow"></view>
    </view>
    <!-- 中间偏左：筛选按钮 -->
    <view wx:if="{{showFilter}}" class="nav-filter" bindtap="onFilter">
      <view class="filter-icon"></view>
    </view>
    <view wx:else class="nav-filter-placeholder"></view>
    <!-- 右侧：搜索框 -->
    <view class="nav-search">
      <view class="search-icon">
        <view class="search-circle"></view>
        <view class="search-handle"></view>
      </view>
      <input
        class="search-input"
        type="text"
        placeholder="{{placeholder}}"
        placeholder-class="search-placeholder"
        value="{{searchKey}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <view wx:if="{{searchKey}}" class="search-clear" bindtap="onSearchClear">
        <text class="clear-text">×</text>
      </view>
    </view>
  </view>
</view>
<!-- 占位，撑开内容区 -->
<view style="height: {{navBarHeight}}px;"></view>
