.profile-page {
  min-height: 100vh;
  background: #f5f6fa;
}

/* 头部 */
.profile-header {
  background: linear-gradient(135deg, #4A90D9, #5BA0E9);
}
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 16rpx;
}
.header-back {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
}
.back-arrow {
  width: 20rpx; height: 20rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(45deg);
  margin-left: 6rpx;
}
.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: #fff;
  margin: -20rpx 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 10;
}
.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #5BA0E9);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}
.avatar-text {
  font-size: 44rpx;
  color: #fff;
  font-weight: 600;
}
.user-info {
  display: flex;
  flex-direction: column;
}
.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}
.user-role {
  font-size: 26rpx;
  color: #999;
}

/* 数据统计 */
.stats-section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}
.stats-grid {
  display: flex;
  justify-content: space-around;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #4A90D9;
  margin-bottom: 8rpx;
}
.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 菜单 */
.menu-section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
}
.menu-row:active { background: #f9f9f9; }
.menu-left {
  display: flex;
  align-items: center;
}
.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}
.icon-history-sm {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #4A90D9;
  border-radius: 50%;
  border-right-color: transparent;
}
.menu-text {
  font-size: 30rpx;
  color: #333;
}
.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0;
}
.version-text {
  font-size: 24rpx;
  color: #ccc;
}
