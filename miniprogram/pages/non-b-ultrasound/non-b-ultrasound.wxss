.nb-list-page { min-height: 100vh; }
.list-area { padding: 24rpx; }

/* 导出栏 */
.export-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.export-count {
  font-size: 26rpx;
  color: #999;
}
.export-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 32rpx;
  background: #E8F2FE;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #4A90D9;
}
.export-btn:active { opacity: 0.8; }
.export-icon { font-size: 28rpx; }

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.record-card:active { opacity: 0.85; }

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.record-animal {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}
.record-tags {
  display: flex;
  gap: 8rpx;
  align-items: center;
}
.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.tag-info { background: #f5f6fa; color: #666; }
.tag-locked { background: #FFF7E6; color: #FAAD14; }
.tag-risk { background: #FFF1F0; color: #FF4D4F; }

/* 高风险标签容器（卡片底部） */
.record-tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.record-bottom {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.record-info {
  font-size: 26rpx;
  color: #666;
}
