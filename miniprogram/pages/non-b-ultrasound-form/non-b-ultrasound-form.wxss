.form-page { min-height: 100vh; padding-bottom: 160rpx; }

.form-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  background: #fff;
  z-index: 999;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
}
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 16rpx;
}
.header-back {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
}
.back-arrow {
  width: 20rpx; height: 20rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}
.header-title {
  font-size: 32rpx; font-weight: 600; color: #333;
}

.lock-banner {
  background: #FFF7E6;
  padding: 20rpx 32rpx;
  text-align: center;
}
.lock-text { font-size: 24rpx; color: #FAAD14; }

.form-group {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.03);
}
.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 48rpx;
}
.form-item:last-child { border-bottom: none; }
.form-item-column {
  flex-direction: column;
  align-items: flex-start;
}
.form-item-column .form-label { margin-bottom: 20rpx; width: auto; }
.form-label {
  width: 200rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #333;
}
.required { color: #FF4D4F; margin-left: 4rpx; }
.form-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.form-placeholder { color: #bbb; }

/* 动物编号：模糊搜索+下拉选择 */
.form-item-animal {
  flex-direction: column;
  align-items: flex-start;
}
.form-item-animal .form-label { margin-bottom: 16rpx; width: auto; }
.animal-search-input {
  font-size: 32rpx;
  padding: 20rpx 24rpx;
  min-height: 56rpx;
}
.animal-empty {
  padding: 40rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}
.form-textarea {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  min-height: 60rpx;
}

/* 检查部位选项 */
.part-options {
  display: flex;
  gap: 16rpx;
}
.part-option {
  padding: 16rpx 40rpx;
  border-radius: 12rpx;
  background: #f5f6fa;
  font-size: 28rpx;
  color: #666;
}
.part-option.selected {
  background: #E8F2FE;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
}

/* 标签式单选 (multi-select-wrap / select-tag) */
.multi-select-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
  padding-top: 4rpx;
}
.select-tag {
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  background: #f5f6fa;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
  line-height: 1.4;
  transition: all 0.2s;
}
.select-tag-active {
  background: #E8F2FE;
  color: #4A90D9;
  border-color: #4A90D9;
  font-weight: 500;
}

.form-actions { padding: 32rpx; }

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-content {
  width: 86%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}
.animal-scroll {
  max-height: 600rpx;
}
.animal-option {
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
}
.animal-option:last-child { border-bottom: none; }
.animal-option:active { background: #f5f6fa; }

.reason-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  padding: 20rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}
.modal-actions {
  display: flex;
  gap: 24rpx;
}
.modal-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx 0;
}
