.b-list-page { min-height: 100vh; }

.filter-panel {
  display: flex;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  gap: 16rpx;
}
.filter-item {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: #f5f6fa;
  font-size: 26rpx;
  color: #666;
}
.filter-item.active {
  background: #4A90D9;
  color: #fff;
}

.list-area { padding: 24rpx; }

/* 导出栏 */
.export-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.export-count {
  font-size: 26rpx;
  color: #999;
}
.export-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 32rpx;
  background: #E8F2FE;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #4A90D9;
}
.export-btn:active { opacity: 0.8; }
.export-icon { font-size: 28rpx; }

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.record-card:active { opacity: 0.85; }

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.record-animal {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}
.record-tags {
  display: flex;
  gap: 8rpx;
}
.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.tag-pregnant { background: #FFF1F0; color: #FF4D4F; }
.tag-not-pregnant { background: #F0F5FF; color: #4A90D9; }
.tag-locked { background: #FFF7E6; color: #FAAD14; }

/* 高风险标签 */
.record-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}
.tag-risk {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #FFF1F0;
  color: #FF4D4F;
}

.record-bottom {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.record-date {
  font-size: 26rpx;
  color: #999;
}
.record-stage {
  font-size: 24rpx;
  color: #666;
  background: #f5f6fa;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.record-age {
  font-size: 24rpx;
  color: #4A90D9;
}
