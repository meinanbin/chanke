<view class="summary-page">
  <nav-bar
    search-key="{{searchKey}}"
    placeholder="请输入动物编号"
    bind:searchchange="onSearchChange"
    bind:search="onSearch"
    bind:filter="onFilter"
  ></nav-bar>

  <!-- 视图切换 Tab -->
  <view class="view-tabs">
    <view class="view-tab {{viewMode === 'all' ? 'view-tab-active' : ''}}" data-mode="all" bindtap="onSwitchView">全部</view>
    <view class="view-tab {{viewMode === 'needRecheck' ? 'view-tab-active' : ''}}" data-mode="needRecheck" bindtap="onSwitchView">当前需复检</view>
    <view class="view-tab {{viewMode === 'highRiskPregnant' ? 'view-tab-active' : ''}}" data-mode="highRiskPregnant" bindtap="onSwitchView">高风险在孕</view>
    <view class="view-tab {{viewMode === 'suspectedPregnant' ? 'view-tab-active' : ''}}" data-mode="suspectedPregnant" bindtap="onSwitchView">疑似怀孕</view>
  </view>

  <!-- 筛选弹层 -->
  <view wx:if="{{showFilter}}" class="filter-panel">
    <view class="filter-item {{filterStatus === '' ? 'active' : ''}}" data-status="" bindtap="onFilterSelect">全部</view>
    <view class="filter-item {{filterStatus === '在孕' ? 'active' : ''}}" data-status="在孕" bindtap="onFilterSelect">在孕</view>
    <view class="filter-item {{filterStatus === '疑似怀孕' ? 'active' : ''}}" data-status="疑似怀孕" bindtap="onFilterSelect">疑似怀孕</view>
    <view class="filter-item {{filterStatus === '未孕' ? 'active' : ''}}" data-status="未孕" bindtap="onFilterSelect">未孕</view>
    <view class="filter-item {{filterStatus === '已结案' ? 'active' : ''}}" data-status="已结案" bindtap="onFilterSelect">已结案</view>
  </view>

  <!-- 列表 -->
  <view class="list-area">
    <view class="export-bar" wx:if="{{list.length > 0}}">
      <text class="export-count">共 {{list.length}} 条记录</text>
      <view class="export-btn" bindtap="onExport">
        <text class="export-icon">📥</text>
        <text>导出Excel</text>
      </view>
    </view>
    <block wx:if="{{list.length > 0}}">
      <view class="summary-card" wx:for="{{list}}" wx:key="animalId" data-id="{{item.animalId}}" bindtap="onItemTap">
        <view class="card-header">
          <text class="animal-id">{{item.animalId}}</text>
          <view class="header-actions">
            <view class="delete-btn" data-id="{{item.animalId}}" catchtap="onDeleteAnimal">删除</view>
            <view class="status-tag tag-{{item.status === '在孕' ? 'pregnant' : item.status === '疑似怀孕' ? 'suspected' : item.status === '未孕' ? 'not-pregnant' : 'closed'}}">
              {{item.status}}
            </view>
          </view>
        </view>
        <view class="card-body">
          <view class="info-row">
            <text class="info-label">最新B超</text>
            <text class="info-value">{{item.latestBUltrasoundDate || '暂无'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">最新非B超</text>
            <text class="info-value">{{item.latestNonBUltrasoundDate || '暂无'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">检查次数</text>
            <text class="info-value">B超{{item.bRecordCount}}次 / 非B超{{item.nonBRecordCount}}次</text>
          </view>
          <view class="info-row" wx:if="{{item.bDaysSince !== null}}">
            <text class="info-label">B超距今检查</text>
            <text class="info-value">{{item.bDaysSince}}天</text>
          </view>
          <view class="info-row" wx:if="{{item.nonBDaysSince !== null}}">
            <text class="info-label">非B超距今检查</text>
            <text class="info-value">{{item.nonBDaysSince}}天</text>
          </view>
        </view>
        <!-- 高风险标签 -->
        <view class="card-tags" wx:if="{{item.mergedRiskTags && item.mergedRiskTags.length > 0}}">
          <text wx:for="{{item.mergedRiskTags}}" wx:for-item="tag" wx:key="*this"
                class="tag {{tag === '弱猴' ? 'tag-weak' : tag === '剖腹产史' ? 'tag-cesarean' : 'tag-risk'}}">{{tag}}</text>
        </view>
        <view class="card-arrow">
          <text class="arrow-text">›</text>
        </view>
      </view>
    </block>

    <view wx:else class="empty-state">
      <view class="empty-icon">📋</view>
      <text class="empty-text">暂无动物档案</text>
      <text class="empty-hint">请通过B超检查创建新档案</text>
    </view>
  </view>

  <!-- 新建B超检查悬浮按钮 -->
  <view class="fab-btn" bindtap="onNewBUltrasound">
    <view class="fab-icon">+</view>
    <text class="fab-text">B超检查</text>
  </view>
</view>
