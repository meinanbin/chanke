.summary-page {
  min-height: 100vh;
}

/* 视图切换 Tab */
.view-tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.view-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.view-tab-active {
  color: #4A90D9;
  font-weight: 600;
}
.view-tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #4A90D9;
}

/* 筛选面板 */
.filter-panel {
  display: flex;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  gap: 16rpx;
}
.filter-item {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: #f5f6fa;
  font-size: 26rpx;
  color: #666;
}
.filter-item.active {
  background: #4A90D9;
  color: #fff;
}

/* 列表区域 */
.list-area {
  padding: 24rpx;
}

/* 导出栏 */
.export-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.export-count {
  font-size: 26rpx;
  color: #999;
}
.export-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 32rpx;
  background: #E8F2FE;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #4A90D9;
}
.export-btn:active { opacity: 0.8; }
.export-icon { font-size: 28rpx; }

/* 汇总卡片 */
.summary-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
}
.summary-card:active { opacity: 0.85; }

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.animal-id {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}
.header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.delete-btn {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  background: #FFF1F0;
  color: #FF4D4F;
  border: 1rpx solid #FFA39E;
}
.delete-btn:active { opacity: 0.7; }
.status-tag {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.tag-pregnant { background: #FFF1F0; color: #FF4D4F; }
.tag-suspected { background: #FFFBE6; color: #FAAD14; }
.tag-not-pregnant { background: #F0F5FF; color: #4A90D9; }
.tag-closed { background: #F5F5F5; color: #999; }

.card-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.info-row {
  display: flex;
  align-items: center;
}
.info-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #999;
}
.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.card-arrow {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
}
.arrow-text {
  font-size: 40rpx;
  color: #ccc;
}

/* 空状态补充 */
.empty-hint {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* 高风险标签 */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}
.tag-risk {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #FFF1F0;
  color: #FF4D4F;
}
.tag-weak {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #FFF0F6;
  color: #C41D7F;
  border: 1rpx solid #FFADD2;
}
.tag-cesarean {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #F0F5FF;
  color: #1D39C4;
  border: 1rpx solid #ADC6FF;
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  right: 32rpx;
  bottom: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
  z-index: 100;
}
.fab-btn:active {
  transform: scale(0.92);
  opacity: 0.9;
}
.fab-icon {
  font-size: 48rpx;
  color: #fff;
  line-height: 1;
  margin-bottom: 2rpx;
}
.fab-text {
  font-size: 18rpx;
  color: #fff;
  line-height: 1.2;
}
